{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "tchori config file (*.tchori.json)",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "providers": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["source", "version"],
        "additionalProperties": false,
        "properties": {
          "source": { "type": "string" },
          "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
          "config": { "type": "object" }
        }
      }
    },
    "resources": {
      "type": "object",
      "propertyNames": {
        "pattern": "^[a-z][a-z0-9_]*\\.[a-z][a-z0-9_-]*$"
      },
      "additionalProperties": {
        "type": "object",
        "required": ["config"],
        "additionalProperties": false,
        "properties": {
          "provider": { "type": "string" },
          "config": { "type": "object" }
        }
      }
    }
  }
}
